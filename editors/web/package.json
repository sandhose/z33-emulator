{
  "name": "z33-web",
  "private": true,
  "type": "module",
  "scripts": {
    "build:wasm": "wasm-pack build ../../crates/wasm --target web --out-dir ../../editors/web/pkg --out-name z33_web",
    "build:wasm:dev": "wasm-pack build ../../crates/wasm --dev --target web --out-dir ../../editors/web/pkg --out-name z33_web",
    "build": "pnpm run build:wasm && vite build",
    "start": "pnpm run build:wasm:dev && vite",
    "check": "oxlint app/ && oxfmt --check app/",
    "lint": "oxlint app/",
    "lint:fix": "oxlint --fix app/",
    "fmt": "oxfmt app/",
    "fmt:check": "oxfmt --check app/",
    "knip": "knip",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:headed": "playwright test --headed"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.3.2",
    "@tsconfig/node20": "^20.1.9",
    "@tsconfig/strictest": "^2.0.8",
    "@tsconfig/vite-react": "^8.0.6",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "knip": "^6.3.0",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "^0.24.0",
    "tailwindcss": "^4.3.2",
    "typescript": "catalog:",
    "vite": "^8.1.3",
    "wasm-pack": "catalog:"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@monaco-editor/react": "^4.7.0",
    "@tanstack/react-pacer": "^0.22.1",
    "@tanstack/react-virtual": "^3.14.5",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.23.0",
    "monaco-editor": "^0.55.1",
    "monaco-languageserver-types": "~0.4.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-resizable-panels": "^4.9.0",
    "shadcn": "^4.12.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "vscode-jsonrpc": "^9.0.1",
    "vscode-languageserver-protocol": "^3.18.1",
    "zustand": "^5.0.14"
  }
}
